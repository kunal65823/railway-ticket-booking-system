NODE_ENV=development
PORT=5000
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_chars
JWT_EXPIRE=7d
# Comma-separated in production, e.g. https://your-frontend.app,https://admin.your-frontend.app
# Localhost/127.0.0.1 origins are allowed automatically while NODE_ENV is not production.
FRONTEND_URL=http://localhost:3000

# Supabase backend configuration
SUPABASE_URL=https://your-project-id.supabase.co
# Required: use the Supabase service_role key for the backend API.
# Do not use the anon key here because users/bookings are protected by RLS.
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_supabase_service_role_key
